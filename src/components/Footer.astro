---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 mt-32">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img src="/favicon.svg" alt="" width="28" height="28" />
          <span class="font-display text-lg text-white">ClearPath</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
          Free, open source browser tools that make the web accessible — for everyone.
        </p>
        <p class="text-white/30 text-xs mt-4">
          Built by the team behind <a href="https://sproutaac.org" class="text-white/50 hover:text-white transition-colors underline underline-offset-2">Sprout AAC</a>
        </p>
      </div>

      <!-- Product -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Product</h3>
        <ul class="space-y-3" role="list">
          <li><a href="/features" class="text-sm text-white/60 hover:text-white transition-colors">Features</a></li>
          <li><a href="/install" class="text-sm text-white/60 hover:text-white transition-colors">Install</a></li>
          <li><a href="/docs/getting-started" class="text-sm text-white/60 hover:text-white transition-colors">Documentation</a></li>
          <li><a href="/docs/api-setup" class="text-sm text-white/60 hover:text-white transition-colors">API Setup</a></li>
          <li><a href="https://github.com/clearpath-ext/clearpath-extension/releases" target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-white transition-colors">Changelog</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Community</h3>
        <ul class="space-y-3" role="list">
          <li>
            <a href="https://github.com/clearpath-ext" target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-white transition-colors">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://github.com/clearpath-ext/clearpath-extension/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-white transition-colors">
              Contribute
            </a>
          </li>
          <li>
            <a href="https://github.com/clearpath-ext/clearpath-extension/issues" target="_blank" rel="noopener noreferrer" class="text-sm text-white/60 hover:text-white transition-colors">
              Report a Bug
            </a>
          </li>
          <li><a href="/privacy" class="text-sm text-white/60 hover:text-white transition-colors">Privacy Policy</a></li>
          <li>
            <a href="mailto:hello@clearpathext.com" class="text-sm text-white/60 hover:text-white transition-colors">
              Contact
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/30">
        © {year} ClearPath. MIT License. No tracking, ever.
      </p>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/5 text-xs text-white/40">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-green animate-glow-pulse" aria-hidden="true" />
          Open source & free
        </span>
      </div>
    </div>
  </div>
</footer>
