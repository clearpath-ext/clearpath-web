---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="Profiles"
  description="Save and share accessibility settings as named profiles — perfect for SLPs and caregivers."
>
  <Nav />

  <main id="main-content" class="pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-6">

      <div class="mb-12">
        <a href="/docs/getting-started" class="text-sm text-white/40 hover:text-white transition-colors">← Getting Started</a>
      </div>

      <h1 class="font-display text-5xl text-white mb-4">Profiles</h1>
      <p class="text-white/50 text-lg mb-12">Save named accessibility configurations and share them as a single file.</p>

      <div class="space-y-10">

        <section>
          <h2 class="font-display text-2xl text-white mb-4">What is a profile?</h2>
          <p class="text-white/60 leading-relaxed">
            A profile is a snapshot of all your ClearPath settings — voice speed, font, colour theme, reading ruler, symbol overlay preferences, and more — saved under a name. You can have multiple profiles and switch between them in one click.
          </p>
          <p class="text-white/60 leading-relaxed mt-3">
            Profiles are especially useful for SLPs, teachers, and caregivers who configure ClearPath for someone else. You can create the perfect setup on your own device, export it as a small JSON file, and hand it to anyone who can import it in seconds.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl text-white mb-4">Creating a profile</h2>
          <ol class="space-y-4">
            {[
              'Open the ClearPath popup by clicking the icon in your toolbar.',
              'Configure your settings exactly as you want them — font, voice, theme, etc.',
              'Go to Profiles → Save current as new profile.',
              'Give the profile a name (e.g. "Reading — High Contrast" or "Sam\'s Settings").',
              'Click Save.',
            ].map((step, i) => (
              <li class="flex gap-4">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-gradient flex items-center justify-center text-navy-900 font-bold text-xs">
                  {i + 1}
                </span>
                <p class="text-white/60 text-sm pt-0.5">{step}</p>
              </li>
            ))}
          </ol>
        </section>

        <section>
          <h2 class="font-display text-2xl text-white mb-4">Exporting and importing</h2>
          <p class="text-white/60 text-sm leading-relaxed mb-6">
            Profiles are stored as plain JSON — easy to inspect, easy to share.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-5 rounded-xl bg-navy-800/40 border border-white/5">
              <h3 class="font-semibold text-white text-sm mb-2">Export</h3>
              <p class="text-white/50 text-xs leading-relaxed">Go to Profiles → select a profile → Export as JSON. Save the file and share it however you like — email, USB, cloud storage.</p>
            </div>
            <div class="p-5 rounded-xl bg-navy-800/40 border border-white/5">
              <h3 class="font-semibold text-white text-sm mb-2">Import</h3>
              <p class="text-white/50 text-xs leading-relaxed">Go to Profiles → Import profile → select the JSON file. The profile will appear in your list immediately.</p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="font-display text-2xl text-white mb-4">Privacy</h2>
          <p class="text-white/60 text-sm leading-relaxed">
            Profiles are stored entirely in your browser's local storage. They are never uploaded anywhere. When you export a profile, the JSON file stays on your device until you choose to share it.
          </p>
        </section>

      </div>

    </div>
  </main>

  <Footer />
</Base>
