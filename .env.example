# Copy this to .env and fill in your values
# Never commit .env to git — it's in .gitignore

# Your Resend API key
# Get it from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The personal email address where hello@clearpathext.com mail gets forwarded
# This is your private inbox — it never appears publicly
FORWARD_TO_EMAIL=you@gmail.com

# A random secret string to verify webhook requests are genuinely from Resend
# Generate one at: https://generate-secret.vercel.app/32
# Add this same string to your Resend webhook config
INBOUND_WEBHOOK_SECRET=your_random_secret_here
